# ── نسخة نموذجية — لا تضع أسرارًا حقيقية في المستودع ──

# مسار قاعدة البيانات (على Render يتطلب قرصًا دائمًا لبقاء البيانات)
DB_PATH=/var/data/whiteout.db

# مفتاح توقيع JWT — ولّده: python -c "import secrets;print(secrets.token_urlsafe(48))"
JWT_SECRET=ضع_مفتاحًا_عشوائيًا_طويلًا_هنا

# حساب المالك (Super Admin) يُنشأ تلقائيًا عند أول تشغيل
SUPER_EMAIL=owner@yourdomain.com
SUPER_PW=غيّرها_فورًا

# توكن الخدمة: يستخدمه المُشرف (supervisor) لرفع التقارير — نفس القيمة في الخدمتين
SERVICE_TOKEN=توكن_خدمة_عشوائي_طويل

# للمُشرف فقط: رابط لوحة الويب على Render
PANEL_URL=https://bot-afcw.onrender.com

# DEBUG=1 يُرجع رموز التفعيل في الاستجابة (للتطوير فقط) — اتركه 0 في الإنتاج
DEBUG=0
